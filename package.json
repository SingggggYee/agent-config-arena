{
  "name": "agent-config-arena",
  "version": "0.1.0",
  "description": "Neutral benchmark arena that tests CLAUDE.md, AGENTS.md, and agent configs against each other on real coding tasks.",
  "type": "module",
  "bin": {
    "agent-config-arena": "./dist/index.js",
    "configbench": "./dist/index.js"
  },
  "files": [
    "dist",
    "configs",
    "tasks",
    "docs"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "keywords": [
    "benchmark",
    "claude",
    "codex",
    "agent",
    "config",
    "arena",
    "CLAUDE.md",
    "AGENTS.md",
    "mcp",
    "coding-agent",
    "ai-coding",
    "developer-tools"
  ],
  "author": "SingggggYee",
  "repository": {
    "type": "git",
    "url": "https://github.com/SingggggYee/agent-config-arena.git"
  },
  "homepage": "https://github.com/SingggggYee/agent-config-arena",
  "bugs": {
    "url": "https://github.com/SingggggYee/agent-config-arena/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.28.2",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "execa": "^9.6.1"
  }
}
